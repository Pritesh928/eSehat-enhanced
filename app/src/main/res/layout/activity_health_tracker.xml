
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Top Header Section with Pills Background -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="300dp"
            android:background="@drawable/gradient_background"
            android:padding="20dp">

            <!-- Status Bar -->
            <LinearLayout
                android:id="@+id/status_bar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_alignParentTop="true">

                <View
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                </LinearLayout>

            </LinearLayout>

            <!-- Pills Icon (Left) -->
            <ImageView
                android:id="@+id/pill_icon_left"
                android:layout_width="60dp"
                android:layout_height="120dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:layout_marginStart="10dp"
                android:rotation="-15"
                android:background="@drawable/pill_shape"
                android:backgroundTint="#40E0FF" />

            <!-- Main Content -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Medicals Nearby"
                    android:textColor="#FFFFFF"
                    android:textSize="32sp"
                    android:layout_marginBottom="30dp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Your PIN code - 400612"
                    android:textColor="#FFF8F8"
                    android:layout_marginBottom="50dp"
                    android:textSize="18sp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="40dp" />


            </LinearLayout>

            <!-- Pills Icon (Right) -->
            <ImageView
                android:id="@+id/pill_icon_right"
                android:layout_width="45dp"
                android:layout_height="90dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:layout_marginEnd="20dp"
                android:rotation="25"
                android:background="@drawable/pill_shape"
                android:backgroundTint="#20A0E0" />

            <!-- Small Pills Scattered -->
            <ImageView
                android:layout_width="25dp"
                android:layout_height="50dp"
                android:layout_alignParentStart="true"
                android:layout_alignParentBottom="true"
                android:layout_marginStart="100dp"
                android:layout_marginBottom="40dp"
                android:rotation="45"
                android:background="@drawable/pill_shape"
                android:backgroundTint="#60C0FF" />

            <ImageView
                android:layout_width="20dp"
                android:layout_height="40dp"
                android:layout_alignParentEnd="true"
                android:layout_alignParentBottom="true"
                android:layout_marginEnd="80dp"
                android:layout_marginBottom="80dp"
                android:rotation="-30"
                android:background="@drawable/pill_shape"
                android:backgroundTint="#80D0FF" />

            <!-- Change Location Button -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_alignParentBottom="true"
                android:layout_marginEnd="20dp"
                android:layout_marginBottom="20dp"
                android:gravity="center"
                android:orientation="horizontal"
                android:padding="12dp">

                <Button
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:id="@+id/profilepageRedirect"
                    android:text="Change your location"
                    android:backgroundTint="@color/black"
                    android:textColor="@color/white"
                    android:textSize="14sp" />

            </LinearLayout>

        </RelativeLayout>

        <!-- Nearby Medicals Section -->

        <!-- Bottom Navigation Placeholder -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:text="Nearby Medicals"
                android:textColor="#000000"
                android:textSize="24sp"
                android:textStyle="bold" />

            <!-- Ayush Medical Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="15dp"
                android:background="@drawable/edittext"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#F5F5F5"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Baymax Medical"
                            android:textColor="#000000"
                            android:textSize="22sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:lineSpacingExtra="2dp"
                            android:text="Location : Shop no. 44, Near Maruti Temple, Gandhi Chowk, Badlapur E, Mumbai, Maharashtra 421503"
                            android:textColor="#666666"
                            android:textSize="14sp" />

                        <Button
                            android:layout_width="200dp"
                            android:layout_height="45dp"
                            android:layout_marginTop="15dp"
                            android:backgroundTint="@color/black"
                            android:text="Check Now"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp" />

                    </LinearLayout>

                </RelativeLayout>

            </androidx.cardview.widget.CardView>

            <!-- Soham Medical Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="15dp"
                android:background="@drawable/edittext"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#F5F5F5"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Interstellar Medical Store"
                            android:textColor="#000000"
                            android:textSize="22sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:lineSpacingExtra="2dp"
                            android:text="Location : Shop No. 12, Opp. Dr. Gandhi Clinic, Dattawaadi, Badlapur E, Mumbai, Maharashtra 421503"
                            android:textColor="#666666"
                            android:textSize="14sp" />

                        <Button
                            android:layout_width="200dp"
                            android:layout_height="45dp"
                            android:layout_marginTop="15dp"
                            android:backgroundTint="@color/black"
                            android:text="Check Now"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp" />

                    </LinearLayout>

                </RelativeLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:background="#FFFFFF" />

    </LinearLayout>
    </ScrollView><!-- BottomNavigation -->
    <RelativeLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:padding="10dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/edittext">
            <!-- Extra space for scrolling -->
            <View
                android:layout_width="42dp"
                android:layout_height="5dp"
                />

            <!-- Home -->
            <ImageButton
                android:id="@+id/homebtn"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/ic_home" />
            <!-- Extra space for scrolling -->
            <View
                android:layout_width="20dp"
                android:layout_height="5dp"
                />

            <!-- Medication -->
            <ImageButton
                android:id="@+id/healthtrackbtn"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/ic_more" />
            <!-- Extra space for scrolling -->
            <View
                android:layout_width="20dp"
                android:layout_height="5dp"
                />

            <!-- consult -->
            <ImageButton
                android:id="@+id/videoconsult"
                android:layout_width="45dp"
                android:layout_height="40dp"
                android:background="@drawable/ic_medication" />
            <!-- Extra space for scrolling -->
            <View
                android:layout_width="20dp"
                android:layout_height="5dp"
                />

            <!-- baymax-->
            <ImageButton
                android:id="@+id/baymaxAI"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/ic_ai_logo" />
            <!-- Extra space for scrolling -->
            <View
                android:layout_width="20dp"
                android:layout_height="5dp"
                />

            <!-- profile page-->

            <ImageButton
                android:id="@+id/profileBtn"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/ic_profile" />

        </LinearLayout>


    </RelativeLayout>
</RelativeLayout>

