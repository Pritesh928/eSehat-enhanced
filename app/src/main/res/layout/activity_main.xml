<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/main1"
    android:background="@color/white">

    <!-- Main ScrollView -->
    <ScrollView
        android:id="@+id/main_scroll_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/bottom_navigation"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Header Section -->
            <RelativeLayout
                android:id="@+id/header_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/curve"
                android:paddingStart="24dp"
                android:paddingTop="50dp"
                android:paddingEnd="24dp"
                android:paddingBottom="32dp">

                <!-- My Medications Title -->
                <TextView
                    android:id="@+id/tv_my_medications"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerHorizontal="true"
                    android:text="My Medications"
                    android:textColor="@android:color/white"
                    android:textSize="18sp" />

                <!-- Greeting -->
                <TextView
                    android:id="@+id/tv_greeting"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/tv_my_medications"
                    android:layout_marginTop="32dp"
                    android:text="Hello, Pritesh!!"
                    android:textColor="@android:color/white"
                    android:textSize="34sp"
                    android:textStyle="bold" />

                <!-- Medications left message -->
                <TextView
                    android:id="@+id/tv_medications_left"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/tv_greeting"
                    android:layout_marginTop="8dp"
                    android:text="You have 2 medications left for today."
                    android:textColor="#B0BEC5"
                    android:textSize="16sp" />

                <!-- Progress Section -->
                <RelativeLayout
                    android:id="@+id/progress_section"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/tv_medications_left"
                    >

                    <!-- Progress Text -->
                    <LinearLayout
                        android:id="@+id/ll_progress_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:orientation="vertical">
                        <LinearLayout
                            android:id="@+id/btn_add_medication"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="30dp"
                            android:background="?android:attr/selectableItemBackground"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:padding="8dp">
                            <TextView
                                android:id="@+id/tv_progress_count"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="2/8"
                                android:layout_marginBottom="5dp"
                                android:textColor="@android:color/white"
                                android:textSize="32sp"
                                android:textStyle="bold" />

                            <ImageButton
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:layout_marginStart="30dp"
                                android:layout_marginBottom="5dp"
                                android:background="@drawable/ic_add_circle"
                                android:gravity="center"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Add"
                                android:layout_marginBottom="5dp"
                                android:textColor="@android:color/white"
                                android:textSize="18sp" />

                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Medications for this week"
                            android:textColor="#B0BEC5"
                            android:textSize="16sp" />

                    </LinearLayout>

                    <!-- Progress Dots -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:orientation="vertical">

                        <!-- First row of dots -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"
                            android:orientation="horizontal">

                            <View
                                android:id="@+id/circle1"
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:layout_marginEnd="8dp"
                                android:background="@drawable/circle_incomplete" />

                            <View
                                android:id="@+id/circle2"
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:layout_marginEnd="8dp"
                                android:background="@drawable/circle_incomplete" />

                            <View
                                android:id="@+id/circle3"
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:layout_marginEnd="8dp"
                                android:background="@drawable/circle_completed" />

                            <View
                                android:id="@+id/circle4"
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:background="@drawable/circle_completed" />

                        </LinearLayout>

                        <!-- Second row of dots -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <View
                                android:id="@+id/circle5"
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:layout_marginEnd="8dp"
                                android:background="@drawable/circle_completed" />

                            <View
                                android:id="@+id/circle6"
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:layout_marginEnd="8dp"
                                android:background="@drawable/circle_completed" />

                            <View
                                android:id="@+id/circle7"
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:layout_marginEnd="8dp"
                                android:background="@drawable/circle_completed" />

                            <View
                                android:id="@+id/circle8"
                                android:layout_width="14dp"
                                android:layout_height="14dp"
                                android:background="@drawable/circle_completed"  />

                        </LinearLayout>

                    </LinearLayout>
                </RelativeLayout>



            </RelativeLayout>

            <!-- Schedule Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginLeft="20dp"
                android:layout_marginRight="20dp"
                android:layout_marginTop="-260dp">
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="270dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        >

                        <Button
                            android:id="@+id/videoconsult_up"
                            android:layout_width="140dp"
                            android:layout_height="75dp"
                            android:text="       Consult"
                            android:fontFamily="sans-serif-black"
                            android:textColor="@color/black"
                            android:backgroundTint="#E4E6E6"
                            />
                        <ImageView
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:layout_marginStart="-115dp"
                            android:layout_marginTop="23dp"
                            android:src="@drawable/consult"
                            />
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginLeft="30dp">

                        <Button
                            android:id="@+id/baymaxAI_up"
                            android:layout_width="140dp"
                            android:layout_height="75dp"
                            android:text="      AskAI"
                            android:fontFamily="sans-serif-black"
                            android:textColor="@color/black"
                            android:backgroundTint="#E4E6E6"
                            />
                        <ImageView
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:layout_marginStart="-115dp"
                            android:layout_marginTop="23dp"
                            android:src="@drawable/ic_ai_logo"
                            />
                    </LinearLayout>
                </LinearLayout>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Your Medication Schedule"
                    android:textColor="@android:color/black"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <!-- Paracetamol Card -->
                <RelativeLayout
                    android:id="@+id/card_paracetamol"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/edittext"
                    android:padding="20dp">

                    <!-- Medication Info -->
                    <LinearLayout
                        android:id="@+id/ll_paracetamol_info"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Paracetamol"
                            android:textColor="@android:color/black"
                            android:textSize="26sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="After Dinner"
                            android:textColor="@android:color/black"
                            android:textSize="18sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Treats High Blood Pressure"
                            android:textColor="#757575"
                            android:textSize="15sp" />

                    </LinearLayout>

                    <!-- Action Buttons -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:orientation="vertical">

                        <Button
                            android:id="@+id/btn_paracetamol_skipped"
                            android:layout_width="110dp"
                            android:layout_height="44dp"
                            android:layout_marginBottom="8dp"
                            android:text="Skipped"
                            android:backgroundTint="#0C1320"
                            android:textAllCaps="false"
                            android:textColor="@android:color/white"
                            android:textSize="16sp" />

                        <Button
                            android:id="@+id/btn_paracetamol_taken"
                            android:layout_width="110dp"
                            android:layout_height="44dp"
                            android:backgroundTint="#48B88C"
                            android:text="Taken"
                            android:textAllCaps="false"
                            android:textColor="@android:color/white"
                            android:textSize="16sp" />

                    </LinearLayout>

                </RelativeLayout>

                <!-- Metformin Card -->
                <RelativeLayout
                    android:id="@+id/card_metformin"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/edittext"
                    android:padding="20dp">

                    <!-- Medication Info -->
                    <LinearLayout
                        android:id="@+id/ll_metformin_info"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Metformin"
                            android:textColor="@android:color/black"
                            android:textSize="26sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="After Dinner"
                            android:textColor="@android:color/black"
                            android:textSize="18sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Lowers blood glucose levels"
                            android:textColor="#757575"
                            android:textSize="15sp" />

                    </LinearLayout>

                    <!-- Action Buttons -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:orientation="vertical">

                        <Button
                            android:id="@+id/btn_metformin_skipped"
                            android:layout_width="110dp"
                            android:layout_height="44dp"
                            android:layout_marginBottom="8dp"
                            android:backgroundTint="#0C1320"
                            android:text="Skipped"
                            android:textAllCaps="false"
                            android:textColor="@android:color/white"
                            android:textSize="16sp" />

                        <Button
                            android:id="@+id/btn_metformin_taken"
                            android:layout_width="110dp"
                            android:layout_height="44dp"
                            android:backgroundTint="#48B88C"
                            android:text="Taken"
                            android:textAllCaps="false"
                            android:textColor="@android:color/white"
                            android:textSize="16sp" />

                    </LinearLayout>

                </RelativeLayout>

                <!-- Extra space for scrolling -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="100dp" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>
    <!-- BottomNavigation -->
    <RelativeLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:padding="10dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/edittext">
            <!-- Extra space for scrolling -->
            <View
                android:layout_width="42dp"
                android:layout_height="5dp"
                />

            <!-- Home -->
                <ImageButton
                    android:id="@+id/homebtn"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/ic_home" />
            <!-- Extra space for scrolling -->
            <View
                android:layout_width="20dp"
                android:layout_height="5dp"
                />

            <!-- Medication -->
            <ImageButton
                android:id="@+id/healthtrackbtn"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/ic_more" />
            <!-- Extra space for scrolling -->
            <View
                android:layout_width="20dp"
                android:layout_height="5dp"
                />

            <!-- consult -->
            <ImageButton
                android:id="@+id/videoconsult"
                android:layout_width="45dp"
                android:layout_height="40dp"
                android:background="@drawable/ic_medication" />
            <!-- Extra space for scrolling -->
            <View
                android:layout_width="20dp"
                android:layout_height="5dp"
                />

            <!-- baymax-->
            <ImageButton
                android:id="@+id/baymaxAI"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/ic_ai_logo" />
            <!-- Extra space for scrolling -->
            <View
                android:layout_width="20dp"
                android:layout_height="5dp"
                />

            <!-- profile page-->

            <ImageButton
                android:id="@+id/profileBtn"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/ic_profile" />

        </LinearLayout>


    </RelativeLayout>
</RelativeLayout>

